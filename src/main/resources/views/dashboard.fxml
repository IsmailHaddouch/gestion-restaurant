<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.restaurant.gestion_restaurant.controllers.DashboardController"
      style="-fx-padding: 25; -fx-background-color: #f4f6f9;">

    <Label text="📊 Dashboard Restaurant"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <!-- Cartes statistiques -->
    <HBox spacing="20">

        <!-- Total commandes -->
        <VBox style="-fx-background-color:#3498db; -fx-padding:20; -fx-background-radius:10;"
              prefWidth="170" alignment="CENTER">
            <Label text="📋 Total"
                   style="-fx-text-fill:white; -fx-font-size:14px;"/>
            <Label fx:id="lblTotal"  text="0"
                   style="-fx-text-fill:white; -fx-font-size:32px; -fx-font-weight:bold;"/>
            <Label text="Commandes"
                   style="-fx-text-fill:white; -fx-font-size:12px;"/>
        </VBox>

        <!-- En attente -->
        <VBox style="-fx-background-color:#f39c12; -fx-padding:20; -fx-background-radius:10;"
              prefWidth="170" alignment="CENTER">
            <Label text="⏳ En attente"
                   style="-fx-text-fill:white; -fx-font-size:14px;"/>
            <Label fx:id="lblAttente" text="0"
                   style="-fx-text-fill:white; -fx-font-size:32px; -fx-font-weight:bold;"/>
            <Label text="Commandes"
                   style="-fx-text-fill:white; -fx-font-size:12px;"/>
        </VBox>

        <!-- En préparation -->
        <VBox style="-fx-background-color:#2980b9; -fx-padding:20; -fx-background-radius:10;"
              prefWidth="170" alignment="CENTER">
            <Label text="🔥 En préparation"
                   style="-fx-text-fill:white; -fx-font-size:14px;"/>
            <Label fx:id="lblPreparation" text="0"
                   style="-fx-text-fill:white; -fx-font-size:32px; -fx-font-weight:bold;"/>
            <Label text="Commandes"
                   style="-fx-text-fill:white; -fx-font-size:12px;"/>
        </VBox>

        <!-- Servies -->
        <VBox style="-fx-background-color:#27ae60; -fx-padding:20; -fx-background-radius:10;"
              prefWidth="170" alignment="CENTER">
            <Label text="✅ Servies"
                   style="-fx-text-fill:white; -fx-font-size:14px;"/>
            <Label fx:id="lblServie" text="0"
                   style="-fx-text-fill:white; -fx-font-size:32px; -fx-font-weight:bold;"/>
            <Label text="Commandes"
                   style="-fx-text-fill:white; -fx-font-size:12px;"/>
        </VBox>

        <!-- Annulées -->
        <VBox style="-fx-background-color:#e74c3c; -fx-padding:20; -fx-background-radius:10;"
              prefWidth="170" alignment="CENTER">
            <Label text="❌ Annulées"
                   style="-fx-text-fill:white; -fx-font-size:14px;"/>
            <Label fx:id="lblAnnulee" text="0"
                   style="-fx-text-fill:white; -fx-font-size:32px; -fx-font-weight:bold;"/>
            <Label text="Commandes"
                   style="-fx-text-fill:white; -fx-font-size:12px;"/>
        </VBox>

    </HBox>

    <!-- Bouton actualiser -->
    <HBox>
        <Button text="🔄 Actualiser le Dashboard" onAction="#handleActualiser"
                style="-fx-background-color:#2c3e50; -fx-text-fill:white;
                       -fx-font-size:13px; -fx-padding:8 20; -fx-background-radius:5;"/>
    </HBox>

    <Separator/>

    <!-- Dernières commandes -->
    <Label text="🕐 Dernières commandes"
           style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#2c3e50;"/>

    <TableView fx:id="tableRecentes" prefHeight="280">
        <columns>
            <TableColumn fx:id="colId"     text="ID"      prefWidth="40"/>
            <TableColumn fx:id="colTable"  text="Table"   prefWidth="55"/>
            <TableColumn fx:id="colClient" text="Client"  prefWidth="130"/>
            <TableColumn fx:id="colPlat"   text="Plat"    prefWidth="150"/>
            <TableColumn fx:id="colQte"    text="Qté"     prefWidth="45"/>
            <TableColumn fx:id="colStatut" text="Statut"  prefWidth="110"/>
            <TableColumn fx:id="colDate"   text="Date"    prefWidth="140"/>
        </columns>
    </TableView>

</VBox>